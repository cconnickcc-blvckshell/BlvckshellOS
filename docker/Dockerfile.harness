# Blvckshell Harness — core API image.
FROM python:3.11-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    POETRY_VERSION=1.8.3 \
    POETRY_VIRTUALENVS_CREATE=false

WORKDIR /app

RUN pip install --no-cache-dir "poetry==${POETRY_VERSION}"

# Install dependencies first for better layer caching.
COPY pyproject.toml ./
RUN poetry install --no-root --without dev --no-interaction --no-ansi || \
    pip install fastapi "uvicorn[standard]" pydantic pydantic-settings redis \
        anthropic supabase httpx structlog python-dotenv

# Copy the application source.
COPY harness ./harness
COPY brains ./brains
COPY memory ./memory
COPY intake ./intake
COPY judgment ./judgment
COPY scripts ./scripts
COPY README.md ./

EXPOSE 8000

CMD ["uvicorn", "harness.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
