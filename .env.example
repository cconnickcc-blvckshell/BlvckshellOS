# Blvckshell Harness configuration.
# Copy to .env and fill in. Every value has a safe default; the harness runs
# fully offline (in-memory bus/memory + deterministic fake LLM) with no keys.

# -- runtime ----------------------------------------------------------------
BLVCKSHELL_ENVIRONMENT=local
BLVCKSHELL_LOG_LEVEL=INFO

# -- message bus / working memory (Redis) -----------------------------------
BLVCKSHELL_REDIS_URL=redis://localhost:6379/0
# Force the in-process bus/memory backends (no Redis needed). Great for dev.
BLVCKSHELL_USE_IN_MEMORY_BUS=false

# Brains loaded in-process, as comma-separated "module:ClassName" import paths.
# Adding a brain is a config change here — never an edit to harness core code.
# Set empty to run no in-process brains (all brains external over the bus).
BLVCKSHELL_WORKER_BRAIN_MODULES=brains.examples.venture:VentureBrain,brains.examples.commander:CommanderBrain,brains.examples.capital:CapitalBrain

# -- persistent memory (Supabase / PostgreSQL) ------------------------------
# Leave blank to use in-memory ledger/doctrine (data is not persisted).
BLVCKSHELL_SUPABASE_URL=
BLVCKSHELL_SUPABASE_KEY=

# -- inference --------------------------------------------------------------
# Claude is the primary inference engine. Without a key, the harness falls back
# to the deterministic offline LLM so everything still runs.
BLVCKSHELL_ANTHROPIC_API_KEY=
BLVCKSHELL_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI (optional)
BLVCKSHELL_OPENAI_API_KEY=
BLVCKSHELL_OPENAI_MODEL=gpt-4o

# Ollama local inference (optional)
BLVCKSHELL_OLLAMA_BASE_URL=http://localhost:11434
BLVCKSHELL_OLLAMA_URL=http://localhost:11434
BLVCKSHELL_OLLAMA_MODEL=qwen2.5:72b

# Force the deterministic offline LLM even if a key is present (tests/CI).
BLVCKSHELL_USE_FAKE_LLM=false

# -- tunables ---------------------------------------------------------------
BLVCKSHELL_WORKING_MEMORY_TTL_SECONDS=86400
BLVCKSHELL_HEARTBEAT_INTERVAL_SECONDS=15
BLVCKSHELL_HEARTBEAT_TIMEOUT_SECONDS=45

# -- frontend ---------------------------------------------------------------
NEXT_PUBLIC_HARNESS_URL=http://localhost:8000
