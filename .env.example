# ─────────────────────────────────────────────────────────────────────────────
# Blvckshell Agent Harness — environment configuration
#
# Copy to `.env` and fill in. Every value here has a safe in-process default,
# so the harness runs end to end with this file left entirely blank.
# All variables are prefixed BLVCKSHELL_.
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime ---
BLVCKSHELL_ENVIRONMENT=local            # local | staging | production
BLVCKSHELL_LOG_LEVEL=INFO
BLVCKSHELL_API_HOST=0.0.0.0
BLVCKSHELL_API_PORT=8000

# --- Message bus ---
# Leave blank to use the in-process bus. Set to use Redis pub/sub.
BLVCKSHELL_REDIS_URL=
# BLVCKSHELL_REDIS_URL=redis://redis:6379/0
BLVCKSHELL_BUS_NAMESPACE=blvckshell

# --- Shared memory / persistence (Supabase / PostgreSQL) ---
# Leave blank to use in-process persistence (non-durable).
BLVCKSHELL_SUPABASE_URL=
BLVCKSHELL_SUPABASE_KEY=
BLVCKSHELL_WORKING_MEMORY_TTL_SECONDS=86400

# --- Inference ---
# stub = deterministic & offline (default). anthropic = Claude. ollama = local.
BLVCKSHELL_INFERENCE_PROVIDER=stub
BLVCKSHELL_ANTHROPIC_API_KEY=
BLVCKSHELL_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
BLVCKSHELL_OLLAMA_BASE_URL=http://localhost:11434
BLVCKSHELL_OLLAMA_MODEL=qwen2.5:14b
BLVCKSHELL_LLM_MAX_TOKENS=2048
BLVCKSHELL_LLM_TEMPERATURE=0.2

# --- Agent loop ---
BLVCKSHELL_MAX_AGENT_ITERATIONS=8
BLVCKSHELL_HEARTBEAT_INTERVAL_SECONDS=15
BLVCKSHELL_HEARTBEAT_GRACE_SECONDS=45

# --- Frontend (Next.js) ---
NEXT_PUBLIC_HARNESS_API_URL=http://localhost:8000
